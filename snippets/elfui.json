{
  "ElfUI macro component": {
    "prefix": "elfc",
    "body": [
      "import { defineHtml } from \"@elfui/core\";",
      "",
      "const ${1:MyComponent} = defineHtml(`",
      "  <div>$0</div>",
      "`);",
      "",
      "export default ${1:MyComponent};"
    ],
    "description": "Create an ElfUI macro component."
  },
  "ElfUI init template": {
    "prefix": "elfinit",
    "body": [
      "import { defineHtml, useRef } from \"@elfui/core\";",
      "",
      "const ${1:title} = useRef(${2:\"Hello ElfUI\"});",
      "",
      "const ${3:handleClick} = () => {",
      "  ${1:title}.set(${4:\"Hello ElfUI\"});",
      "};",
      "",
      "export default defineHtml(`",
      "  <main class=\"${5:app}\">",
      "    <h1>\\${${1:title}}</h1>",
      "    <button type=\"button\" @click=\\${${3:handleClick}}>$0</button>",
      "  </main>",
      "`);"
    ],
    "description": "Create an ElfUI macro component with starter state and handler."
  },
  "ElfUI lifecycle template ref": {
    "prefix": "elflifecycle",
    "body": [
      "import { defineHtml, onMounted, onUnmounted, useTemplateRef } from \"@elfui/core\";",
      "",
      "const ${1:element} = useTemplateRef<${2:HTMLElement}>(\"${1:element}\");",
      "",
      "onMounted(() => {",
      "  ${1:element}.value?.focus?.();",
      "});",
      "",
      "onUnmounted(() => {",
      "  $0",
      "});",
      "",
      "export default defineHtml(`",
      "  <div ref=\"${1:element}\"></div>",
      "`);"
    ],
    "description": "Create an ElfUI component with lifecycle hooks and a typed template ref."
  }
}
