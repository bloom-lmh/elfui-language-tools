{
  "ElfUI macro component": {
    "prefix": "elfc",
    "body": [
      "import { defineHtml } from \"@elfui/core\";",
      "",
      "const ${1:MyComponent} = defineHtml(`",
      "  <div>$0</div>",
      "`);",
      "",
      "export default ${1:MyComponent};"
    ],
    "description": "Create an ElfUI macro component."
  },
  "ElfUI init template": {
    "prefix": "elfinit",
    "body": [
      "import { defineHtml, useRef } from \"@elfui/core\";",
      "",
      "const ${1:title} = useRef(${2:\"Hello ElfUI\"});",
      "",
      "const ${3:handleClick} = () => {",
      "  ${1:title}.set(${4:\"Hello ElfUI\"});",
      "};",
      "",
      "export default defineHtml(`",
      "  <main class=\"${5:app}\">",
      "    <h1>\\${${1:title}}</h1>",
      "    <button type=\"button\" @click=\\${${3:handleClick}}>$0</button>",
      "  </main>",
      "`);"
    ],
    "description": "Create an ElfUI macro component with starter state and handler."
  }
}
